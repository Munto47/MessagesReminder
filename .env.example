# ---------- 方式 A（推荐）：动态请求加密，每轮自动生成新 encrypt-flag + params，避免旧参数 500 ----------
# 列表接口 base，不要带 ?params=
# API_BASE_URL=https://gqhw.jxmediacenter.com/prod-api/message/message/list
#
# 待加密明文：只能是「参数体」本身，不要写成 params=pageNum=1&…（params= 只出现在浏览器 URL 里，由代码拼接）
# 测试时可依次试：
#   1) API_REQUEST_PLAIN=pageNum=1&pageSize=10
#   2) API_REQUEST_PLAIN=   （留空：须写键名 API_REQUEST_PLAIN= 表示空串，测后端默认分页）
#   3) API_REQUEST_PLAIN_JSON={"pageNum":1,"pageSize":10}
# API_REQUEST_PLAIN=pageNum=1&pageSize=20

# ---------- 方式 B：静态重放抓包 URL + 同次抓包的请求头 encrypt-flag ----------
# 第三方消息接口：须为浏览器 Network 里 XHR 的完整 URL（含 /prod-api/... 与 params= 密文），不要填站点首页
# API_URL=https://gqhw.jxmediacenter.com/prod-api/message/message/list?params=...
API_URL=

# 请求头 Authorization 中的 Bearer Token（不要带 "Bearer " 前缀，代码里会加）
API_BEARER_TOKEN=

# Server酱 SendKey（Server酱³）
SERVERCHAN_SENDKEY=

# 本地状态文件路径（最新消息 ID、Token 告警节流时间）
STATE_FILE=./data/last_state.json

# 可选：抓包「请求」里的 encrypt-flag（重放固定 params 时用；与「响应」里用于解密的 encrypt-flag 不是同一个）
# API_REQUEST_ENCRYPT_FLAG=

# 可选：部分网关校验 Referer
# API_REFERER=https://example.com/

# 可选：覆盖默认 Edge UA（默认已内置浏览器 UA，避免 axios 默认 UA 被拦）
# HTTP_USER_AGENT=
# HTTP_ACCEPT=*/*
# HTTP_X_CLIENT_TYPE=app




# 可选：拉取超时（毫秒）
# REQUEST_TIMEOUT_MS=20000

# 可选：401 告警最小间隔（毫秒），避免短时间内重复推送
# TOKEN_ALERT_COOLDOWN_MS=3600000

# 可选：推送请求超时（毫秒）
# NOTIFY_TIMEOUT_MS=20000

# 可选：设为 1 时打印本次响应头键名（便于排查 encrypt-flag 实际名称）
# POLL_DEBUG_HEADERS=1

# 可选：设为 1 时打印 HTTP 状态码、响应头键名、响应体前 800 字符（调试用）
# POLL_DEBUG_BODY=1

# 可选：设为 1 时打印解密后结构、消息列表匹配路径、条数、lastMessageId 是否写入等（排查解析用）
# POLL_DEBUG_PARSE=1

# 可选：若接口的加密标记头不是 encrypt-flag，在此填写完整头名（如 My-Encrypt-Flag）
# ENCRYPT_FLAG_HEADER=
